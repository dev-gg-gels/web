---
import { Image } from 'astro:assets';
import fourOnBag from '../../public/images/four-on-bag.jpg';
import { getT } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

const locale = (Astro.currentLocale ?? 'nb') as Locale;
const t = getT(locale).finalCta;
---

<section class="bg-cream py-20 md:py-28">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <Image
        src={fourOnBag}
        alt={t.imageAlt}
        class="w-full object-cover aspect-square"
        widths={[400, 700]}
        sizes="(max-width: 768px) 100vw, 50vw"
        format="avif"
      />
      <div>
        <p class="text-muted text-sm tracking-[0.2em] uppercase mb-4">{t.eyebrow}</p>
        <h2 class="text-ink font-display text-3xl md:text-4xl leading-snug mb-6">{t.title}</h2>
        <p class="text-muted leading-relaxed mb-8">{t.body}</p>
        <a
          href="#venteliste"
          class="inline-block bg-ink text-cream font-sans px-8 py-4 tracking-wide hover:bg-ink/80 transition-colors duration-200"
        >
          {t.cta} &rarr;
        </a>
      </div>
    </div>
  </div>
</section>
