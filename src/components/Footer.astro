---
import { site } from '../config/site';
import { getT } from '../i18n/utils';
import type { Locale } from '../i18n/translations';
import Logo from './Logo.astro';

const locale = (Astro.currentLocale ?? 'nb') as Locale;
const t = getT(locale).footer;
const copyright = t.copyright.replace('{year}', String(new Date().getFullYear()));
---

<footer class="bg-ink text-cream/50 py-12">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-8">
      <div>
        <p class="mb-1"><Logo size="xl" /></p>
        <p class="text-sm">{t.tagline}</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-6 text-sm">
        <a href={`mailto:${site.email}`} class="hover:text-cream transition-colors">
          {t.email}
        </a>
        <a href={site.instagram} class="hover:text-cream transition-colors" target="_blank" rel="noopener noreferrer">
          {t.instagramLabel}
        </a>
        <a href="#venteliste" class="hover:text-cream transition-colors">
          {t.waitlistLabel}
        </a>
      </div>
    </div>

    <div class="border-t border-cream/10 pt-8 flex flex-col sm:flex-row justify-between gap-2 text-xs">
      <p>{copyright}</p>
      <p>{t.location}</p>
    </div>
  </div>
</footer>
