---
import { waitlistConfig } from '../config/waitlist';
import { getT } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

const locale = (Astro.currentLocale ?? 'nb') as Locale;
const t = getT(locale).waitlist;
const { earlyBirdDiscount, maxEarlyBird } = waitlistConfig;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';

const sectionTitle = t.title.replace('{max}', String(maxEarlyBird));
const sectionBody = t.body.replace('{discount}', earlyBirdDiscount);
const successBody = t.successBody.replace('{discount}', earlyBirdDiscount);
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<section id="venteliste" class="bg-ink py-20 md:py-28">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <p class="text-tee text-sm tracking-[0.2em] uppercase mb-4">{t.eyebrow}</p>
    <h2 class="text-cream font-display text-3xl md:text-4xl leading-snug mb-4">{sectionTitle}</h2>
    <p class="text-cream/70 text-lg leading-relaxed mb-10">{sectionBody}</p>

    <form id="waitlist-form" class="text-left space-y-5" novalidate>
      <div>
        <label for="email" class="block text-cream/80 text-sm mb-2">
          {t.emailLabel} <span class="text-tee">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder={t.emailPlaceholder}
          class="w-full bg-cream/10 border border-cream/20 text-cream placeholder-cream/30 px-4 py-3 focus:outline-none focus:border-tee focus-visible:ring-2 focus-visible:ring-tee transition-colors duration-200"
        />
      </div>

      <fieldset>
        <legend class="text-cream/80 text-sm mb-3">{t.handicapLegend}</legend>
        <div class="grid grid-cols-2 gap-2">
          {t.handicapOptions.map(({ value, label }) => (
            <label class="flex items-center gap-3 border border-cream/20 px-4 py-3 cursor-pointer hover:border-cream/40 transition-colors has-[:checked]:border-tee has-[:checked]:bg-tee/10">
              <input type="radio" name="handicap" value={value} class="accent-tee" />
              <span class="text-cream/80 text-sm">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-cream/80 text-sm mb-3">{t.frequencyLegend}</legend>
        <div class="grid grid-cols-2 gap-2">
          {t.frequencyOptions.map(({ value, label }) => (
            <label class="flex items-center gap-3 border border-cream/20 px-4 py-3 cursor-pointer hover:border-cream/40 transition-colors has-[:checked]:border-tee has-[:checked]:bg-tee/10">
              <input type="radio" name="frequency" value={value} class="accent-tee" />
              <span class="text-cream/80 text-sm">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-cream/80 text-sm mb-3">{t.currentSolutionLegend}</legend>
        <div class="grid grid-cols-2 gap-2">
          {t.currentSolutionOptions.map(({ value, label }) => (
            <label class="flex items-center gap-3 border border-cream/20 px-4 py-3 cursor-pointer hover:border-cream/40 transition-colors has-[:checked]:border-tee has-[:checked]:bg-tee/10">
              <input type="radio" name="currentSolution" value={value} class="accent-tee" />
              <span class="text-cream/80 text-sm">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-cream/80 text-sm mb-3">
          {t.prioritiesLegend} <span class="text-cream/40">({t.prioritiesHint})</span>
        </legend>
        <div class="grid grid-cols-2 gap-2">
          {t.prioritiesOptions.map(({ value, label }) => (
            <label class="flex items-center gap-3 border border-cream/20 px-4 py-3 cursor-pointer hover:border-cream/40 transition-colors has-[:checked]:border-tee has-[:checked]:bg-tee/10">
              <input type="checkbox" name="priorities" value={value} class="accent-tee" />
              <span class="text-cream/80 text-sm">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-cream/80 text-sm mb-3">{t.priceLegend}</legend>
        <div class="grid grid-cols-2 gap-2">
          {t.priceOptions.map(({ value, label }) => (
            <label class="flex items-center gap-3 border border-cream/20 px-4 py-3 cursor-pointer hover:border-cream/40 transition-colors has-[:checked]:border-tee has-[:checked]:bg-tee/10">
              <input type="radio" name="priceWillingness" value={value} class="accent-tee" />
              <span class="text-cream/80 text-sm">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-cream/80 text-sm mb-3">{t.attributionLegend}</legend>
        <div class="grid grid-cols-2 gap-2">
          {t.attributionOptions.map(({ value, label }) => (
            <label class="flex items-center gap-3 border border-cream/20 px-4 py-3 cursor-pointer hover:border-cream/40 transition-colors has-[:checked]:border-tee has-[:checked]:bg-tee/10">
              <input type="radio" name="attribution" value={value} class="accent-tee" />
              <span class="text-cream/80 text-sm">{label}</span>
            </label>
          ))}
        </div>
        <div id="attribution-other-wrapper" class="hidden mt-3">
          <label for="attribution-other" class="block text-cream/80 text-sm mb-2">
            {t.attributionOtherLabel} <span class="text-tee">*</span>
          </label>
          <input
            type="text"
            id="attribution-other"
            name="attributionOther"
            maxlength="200"
            placeholder={t.attributionOtherPlaceholder}
            class="w-full bg-cream/10 border border-cream/20 text-cream placeholder-cream/30 px-4 py-3 focus:outline-none focus:border-tee focus-visible:ring-2 focus-visible:ring-tee transition-colors duration-200"
          />
        </div>
      </fieldset>

      <div>
        <label for="club" class="block text-cream/80 text-sm mb-2">
          {t.clubLabel} <span class="text-cream/40">({t.clubHint})</span>
        </label>
        <input
          type="text"
          id="club"
          name="club"
          maxlength="100"
          placeholder={t.clubPlaceholder}
          class="w-full bg-cream/10 border border-cream/20 text-cream placeholder-cream/30 px-4 py-3 focus:outline-none focus:border-tee focus-visible:ring-2 focus-visible:ring-tee transition-colors duration-200"
        />
      </div>

      <div>
        <label class="flex items-start gap-3 text-cream/80 text-sm cursor-pointer">
          <input
            type="checkbox"
            id="consent"
            name="consent"
            required
            class="mt-1 accent-tee shrink-0"
          />
          <span set:html={t.consentLabelHtml} />
        </label>
        <p id="consent-error" class="hidden mt-2 text-red-300 text-xs">
          {t.consentRequiredError}
        </p>
      </div>

      <div class="flex justify-center">
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-tee text-ink font-sans font-bold py-4 tracking-wide hover:bg-yellow-300 transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cream"
      >
        {t.submitLabel}
      </button>

      <p class="text-cream/40 text-xs text-center">{t.privacyNote}</p>
    </form>

    <div id="success-message" class="hidden text-center py-8">
      <div class="text-4xl mb-4">{t.successEmoji}</div>
      <h3 class="text-cream font-display text-2xl mb-3">{t.successTitle}</h3>
      <p class="text-cream/70 leading-relaxed">{successBody}</p>
    </div>

    <div id="already-registered-message" class="hidden text-center py-8">
      <div class="text-4xl mb-4">{t.successEmoji}</div>
      <h3 class="text-cream font-display text-2xl mb-3">{t.alreadyRegisteredTitle}</h3>
      <p class="text-cream/70 leading-relaxed" set:html={t.alreadyRegisteredBody.replace(
        'hei@gg-gels.no',
        '<a href="mailto:hei@gg-gels.no" class="underline">hei@gg-gels.no</a>'
      )} />
    </div>

    <div id="error-message" class="hidden mt-4 p-4 border border-red-400/30 bg-red-400/10">
      <p class="text-red-300 text-sm" set:html={t.errorBody.replace(
        'hei@gg-gels.no',
        '<a href="mailto:hei@gg-gels.no" class="underline">hei@gg-gels.no</a>'
      )} />
    </div>
  </div>
</section>

<script is:inline define:vars={{ submitLabel: t.submitLabel, submittingLabel: t.submittingLabel, locale }}>
  const form = document.getElementById('waitlist-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('success-message');
  const alreadyRegisteredMsg = document.getElementById('already-registered-message');
  const errorMsg = document.getElementById('error-message');

  const attributionOtherWrapper = document.getElementById('attribution-other-wrapper');
  const attributionOtherInput = /** @type {HTMLInputElement | null} */ (
    document.getElementById('attribution-other')
  );
  document.querySelectorAll('input[name="attribution"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      const checked = /** @type {HTMLInputElement | null} */ (
        document.querySelector('input[name="attribution"]:checked')
      );
      const isOther = checked?.value === 'other';
      attributionOtherWrapper?.classList.toggle('hidden', !isOther);
      if (!isOther && attributionOtherInput) attributionOtherInput.value = '';
    });
  });

  if (form && submitBtn && successMsg && errorMsg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = /** @type {HTMLInputElement} */ (document.getElementById('email'));
      if (!emailInput?.value || !emailInput.validity.valid) {
        emailInput?.focus();
        return;
      }

      const data = new FormData(form);

      const consentInput = /** @type {HTMLInputElement | null} */ (
        document.getElementById('consent')
      );
      const consentError = document.getElementById('consent-error');
      if (!consentInput?.checked) {
        consentError?.classList.remove('hidden');
        consentInput?.focus();
        return;
      }
      consentError?.classList.add('hidden');

      if (data.get('attribution') === 'other' && !String(data.get('attributionOther') || '').trim()) {
        attributionOtherInput?.focus();
        return;
      }

      const turnstileToken = data.get('cf-turnstile-response');

      if (!turnstileToken) {
        errorMsg.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = submittingLabel;
      errorMsg.classList.add('hidden');

      try {
        const response = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            email: data.get('email'),
            handicap: data.get('handicap'),
            frequency: data.get('frequency'),
            currentSolution: data.get('currentSolution'),
            priorities: data.getAll('priorities'),
            priceWillingness: data.get('priceWillingness'),
            attribution: data.get('attribution'),
            attributionOther: data.get('attributionOther'),
            club: data.get('club'),
            consent: true,
            locale,
            turnstileToken,
          }),
        });

        if (response.ok) {
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else if (response.status === 409) {
          const body = await response.json().catch(() => ({}));
          if (body?.error === 'already_registered' && alreadyRegisteredMsg) {
            form.classList.add('hidden');
            alreadyRegisteredMsg.classList.remove('hidden');
            alreadyRegisteredMsg.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            throw new Error('Server error');
          }
        } else {
          throw new Error('Server error');
        }
      } catch {
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
        if (globalThis.turnstile) globalThis.turnstile.reset();
      }
    });
  }
</script>
