---
import { getImage } from 'astro:assets';
import heroWide from '../../public/images/hero-wide.png';
import heroWideMobile from '../../public/images/hero-wide_mobile.png';
import { getT } from '../i18n/utils';
import type { Locale } from '../i18n/translations';
import { MOBILE_MEDIA } from '../utils/breakpoints';

const locale = (Astro.currentLocale ?? 'nb') as Locale;
const t = getT(locale).hero;

const desktopImg = await getImage({ src: heroWide, widths: [1024, 1440], sizes: '100vw' });
const mobileImg = await getImage({ src: heroWideMobile, widths: [390, 640], sizes: '100vw' });
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-ink">
  <picture class="absolute inset-0 w-full h-full">
    <source media={MOBILE_MEDIA} srcset={mobileImg.srcSet.attribute} sizes="100vw" />
    <img
      src={desktopImg.src}
      srcset={desktopImg.srcSet.attribute}
      sizes="100vw"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-50"
      loading="eager"
      fetchpriority="high"
    />
  </picture>

  <!-- Gradient scrim: sikrer WCAG AA (≥4.5:1) for all tekst uansett bildeinnhold.
       via-ink/80 gir effektiv bakgrunn L≈0.10 → text-cream gir 5.99:1 kontrastforhold. -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-ink via-ink/80 to-ink/20"
    aria-hidden="true"
  />

  <div class="relative z-10 max-w-5xl mx-auto px-6 py-24 md:py-32">
    <p class="text-tee font-sans text-sm tracking-[0.2em] uppercase mb-6 font-bold">
      {t.eyebrow}
    </p>

    <h1 class="text-cream font-display text-4xl md:text-6xl lg:text-7xl leading-tight mb-6 max-w-3xl">
      {t.title.split('\n').map((line, i) => (
        <>{line}{i === 0 && <br />}</>
      ))}
    </h1>

    <p class="text-cream text-lg md:text-xl max-w-xl mb-10 leading-relaxed">
      {t.body}
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="#venteliste"
        class="inline-block bg-tee text-ink font-sans font-bold px-8 py-4 text-base tracking-wide hover:bg-yellow-300 transition-colors duration-200"
      >
        {t.ctaPrimary} &rarr;
      </a>
      <a
        href="#system"
        class="inline-block border border-cream/70 text-cream px-8 py-4 text-base tracking-wide hover:border-cream hover:bg-cream/5 transition-colors duration-200"
      >
        {t.ctaSecondary}
      </a>
    </div>

    <p class="text-cream/80 mt-8">{t.earlyBirdNote}</p>
  </div>
</section>
